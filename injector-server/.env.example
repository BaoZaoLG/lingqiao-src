# Lingqiao server runtime configuration

# Admin panel and client API HTTPS port.
PORT=48901

# Agent panel HTTPS port.
AGENT_PORT=38472

# JSON persistence directory.
DATA_DIR=data

# Default session TTL used by new platform services.
SESSION_TTL=4h

# Set a fixed admin password on first run. If omitted, one is generated.
ADMIN_PASSWORD=

# Set a fixed HMAC secret for client API signing. If omitted, one is generated.
HMAC_SECRET=

# Explicit credentialed CORS origins for browser admin/agent panels.
# Leave empty for same-origin only.
ADMIN_ORIGIN=
AGENT_ORIGIN=

# Hostname/IP used when generating a self-signed TLS certificate.
CERT_HOST=127.0.0.1
